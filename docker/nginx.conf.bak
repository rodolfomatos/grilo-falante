upstream visualizer_backend {
    server 127.0.0.1:8005;
}

upstream openwebui_backend {
    server 127.0.0.1:8081;
}

upstream api_backend {
    server 127.0.0.1:8010;
}

upstream grilo_api {
    server 127.0.0.1:8010;
}

server {
    if ($host = llm.ilab.uporto.pt) {
        return 301 https://$host$request_uri;
    }

    listen 80;
    server_name llm.ilab.uporto.pt;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name llm.ilab.uporto.pt;

    ssl_certificate /etc/letsencrypt/live/llm.ilab.porto.pt/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/llm.ilab.porto.pt/privkey.pem;

    allow 193.137.54.7;
    allow 193.137.54.6;
    allow 193.137.29.105;
    deny all;

    location ~ ^/(ws/)?socket.io/ {
        proxy_pass http://openwebui_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }

    location /api {
        allow 193.137.29.105;
        allow 193.137.29.72;
        allow 193.137.54.7;
        allow 127.0.0.0/8;
        deny all;

        proxy_pass http://api_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        client_max_body_size 200M;
    }

    location /grilo {
        allow 193.137.54.7;
        allow 193.137.54.6;
        allow 193.137.29.105;
        allow 127.0.0.0/8;
        deny all;

        rewrite ^/grilo(.*)$ $1 break;
        proxy_pass http://grilo_api;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        client_max_body_size 200M;
    }

    location /visualizer {
        allow 193.137.54.7;
        allow 193.137.54.6;
        allow 193.137.29.105;
        allow 127.0.0.0/8;
        deny all;

        rewrite ^/visualizer(.*)$ $1 break;
        proxy_pass http://visualizer_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /hub {
        allow 193.137.54.7;
        allow 193.137.54.6;
        allow 193.137.29.105;
        allow 127.0.0.0/8;
        deny all;

        proxy_pass http://visualizer_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        if ($request_uri = '/') {
            return 302 /?web-search=true;
        }

        proxy_pass http://openwebui_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        client_max_body_size 200M;
    }
}
