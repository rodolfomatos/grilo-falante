# Grilo Falante v3.0 Configuration
# Copy to .env and fill in values

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grilo_falante
POSTGRES_PASSWORD=postgres

# =============================================================================
# API AUTHENTICATION (Bearer Token)
# =============================================================================
# Generate a secure token: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=

# Rate limiting (requests per minute per token)
API_RATE_LIMIT=60

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# LLM PROVIDER SELECTION
# =============================================================================
# Options: ollama, openai, iaedu, openwebui, anthropic
LLM_PROVIDER=ollama

# =============================================================================
# OLLAMA (Local LLM)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.3
OLLAMA_NUM_CTX=4096

# =============================================================================
# OPENAI (GPT-4o)
# =============================================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3

# =============================================================================
# ANTHROPIC (Claude)
# =============================================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet

# =============================================================================
# IAEDU (University of Porto Academic API)
# =============================================================================
# Get API key from https://iaedu.pt
IAEDU_API_KEY=
IAEDU_ENDPOINT=https://api.iaedu.pt/agent-chat/api/v1/agent/cmamvd3n40000c801qeacoad2/stream
IAEDU_CHANNEL_ID=cmh0rfgmn0i64j801uuoletwy

# =============================================================================
# OPENWEBUI
# =============================================================================
OPENWEBUI_BASE_URL=http://localhost:8080
OPENWEBUI_API_KEY=dummy

# =============================================================================
# OPENEDATALOADER PDF (Local mode - Java processing only)
# =============================================================================
# Path to OpenDataLoader JAR (if not in PATH)
# OPENEDATALOADER_JAVA_PATH=/path/to/opendataloader-pdf-cli.jar
OPENEDATALOADER_MODE=local

# =============================================================================
# PATHS
# =============================================================================
LAKE_PATH=./lake

# =============================================================================
# EPISTEMIC THRESHOLDS
# =============================================================================
# Minimum evidence score to consider a claim valid
EVIDENCE_THRESHOLD=0.5

# M4 (doubtful testimony) blocking threshold
M4_BLOCK_THRESHOLD=0.4

# Curator scoring
CURATOR_REWARD=0.05
CURATOR_PENALTY=0.1
CURATOR_SUSPENSION_THRESHOLD=0.3

# =============================================================================
# FEATURES
# =============================================================================
# Enable graph lint checks (L1-L8 epistemic integrity)
LINT_ENABLED=true
