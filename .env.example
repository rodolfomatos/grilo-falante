# Grilo Falante v3.0 - Environment Configuration
# Copy this file to .env and fill in your values

# JWT Secret for authentication
# IMPORTANT: Change this in production!
GRILO_JWT_SECRET=changeme-in-production

# PostgreSQL (optional)
DB_PASSWORD=grilo123

# MemPalace (optional)
MEMPALACE_PATH=/path/to/mempalace/data

# Storage
GRILO_STORAGE_PATH=/app/data/ilhas.json

# AutoMem (optional - disabled by default)
# Set to true to enable AutoMem as first-pass recall layer
AUTOMEM_ENABLED=false
FALKORDB_URL=http://localhost:8001
QDRANT_URL=http://localhost:6333
AUTOMEM_COLLECTION=grilo_falante
# Dual-write: store in both AutoMem and MemPalace
AUTOMEM_DUAL_WRITE=false
